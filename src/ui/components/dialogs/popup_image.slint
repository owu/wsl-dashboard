import { Theme, AppI18n, LayoutConstants } from "../../theme.slint";

export component PopupImageDialog inherits Rectangle {
    in property <image> image_source;
    in property <string> title: "";
    in property <string> url: "";
    in property <int> dialog_width: 400;
    in property <int> dialog_height: 300;

    callback close;
    callback image_clicked;

    // Dynamic width/height, set from API-returned width/height
    width: root.dialog_width * 1px;
    height: root.dialog_height * 1px;
    background: Theme.card_bg;
    border-radius: 12px;
    clip: true;
    drop-shadow-blur: 20px;
    drop-shadow-color: #00000040;

    // Image area
    Rectangle {
        background: Theme.content_bg;

        Image {
            source: root.image_source;
            width: 100%;
            height: 100%;
            image-fit: contain;
        }

        // Image click area
        image-touch := TouchArea {
            mouse-cursor: pointer;
            clicked => { root.image_clicked(); }
        }

        // Show title on hover (top-left, corresponding to close button on the right)
        if image-touch.has-hover && root.title != "" : Rectangle {
            x: 8px;
            y: 8px;
            height: 28px;
            width: parent.width - close-btn.width - 24px;
            background: #CC333333;
            border-radius: 14px;

            HorizontalLayout {
                padding-left: 12px;
                padding-right: 12px;

                Text {
                    text: root.title;
                    font-size: 13px * LayoutConstants.font-scale;
                    font-family: Theme.default_font;
                    color: #FFFFFF;
                    vertical-alignment: center;
                    overflow: elide;
                }
            }
        }

        // Top-right circular close button
        close-btn := TouchArea {
            x: parent.width - self.width - 8px;
            y: 8px;
            width: 28px;
            height: 28px;
            clicked => { root.close(); }

            Rectangle {
                background: close-btn.has-hover ? #FF1A1A : #CC333333;
                border-radius: self.width / 2;
                clip: true;

                Text {
                    text: "\u{E8BB}";
                    font-family: Theme.icon_font;
                    font-size: 12px;
                    color: #FFFFFF;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }
    }
}
