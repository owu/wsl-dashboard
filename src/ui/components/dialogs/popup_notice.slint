import { Theme, AppI18n, LayoutConstants } from "../../theme.slint";
import { CustomButton } from "../form_widgets.slint";

export component PopupNoticeDialog inherits Rectangle {
    in property <string> title: "";
    in property <string> msg1: "";
    in property <string> msg2: "";
    in property <string> msg3: "";
    in property <string> hint_text: "";
    in property <string> link_text: "";
    in property <string> url: "";
    // highlight: supports "msg1", "msg2", "msg3" to highlight the corresponding message line
    in property <string> highlight: "";
    // confirm: 1 shows the bottom confirm button, 0 hides it
    in property <int> confirm: 0;

    callback close;
    callback link_clicked;

    width: 480px;
    height: layout.preferred-height;
    background: Theme.card_bg;
    border-radius: 8px;
    border-width: 1px;
    border-color: Theme.border_color;
    drop-shadow-blur: 16px;
    drop-shadow-color: #00000040;

    layout := VerticalLayout {
        padding: 24px;
        spacing: 12px;
        alignment: start;

        // Title + close button
        Rectangle {
            height: 24px;
            Text {
                x: AppI18n.is-rtl ? 32px : 0;
                width: parent.width - 32px;
                text: root.title;
                font-size: 18px * LayoutConstants.font-scale;
                font-family: Theme.default_font;
                font-weight: 500;
                color: Theme.text_primary;
                horizontal-alignment: AppI18n.is-rtl ? right : left;
                vertical-alignment: center;
            }
            TouchArea {
                x: AppI18n.is-rtl ? 0 : parent.width - self.width;
                width: 24px;
                height: 24px;
                clicked => { root.close(); }
                Rectangle {
                    background: parent.has-hover ? Theme.hover_bg : transparent;
                    border-radius: 4px;
                    Text {
                        text: "\u{E8BB}";
                        font-family: Theme.icon_font;
                        font-size: 14px;
                        color: Theme.text_primary;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        // Divider
        Rectangle { height: 1px; background: Theme.border_color; }

        // Message body
        VerticalLayout {
            spacing: 14px;

            // msg1 - highlighted based on highlight value
            if root.msg1 != "": Text {
                text: root.msg1;
                font-size: 14px * LayoutConstants.font-scale;
                font-family: Theme.default_font;
                color: root.highlight == "msg1" ? Theme.icon_color_danger : Theme.text_primary;
                wrap: word-wrap;
                horizontal-alignment: AppI18n.is-rtl ? right : left;
            }

            // msg2 - highlighted based on highlight value
            if root.msg2 != "": Text {
                text: root.msg2;
                font-size: 14px * LayoutConstants.font-scale;
                font-family: Theme.default_font;
                color: root.highlight == "msg2" ? Theme.icon_color_danger : Theme.text_primary;
                wrap: word-wrap;
                horizontal-alignment: AppI18n.is-rtl ? right : left;
            }

            // msg3 - highlighted based on highlight value
            if root.msg3 != "": Text {
                text: root.msg3;
                font-size: 14px * LayoutConstants.font-scale;
                font-family: Theme.default_font;
                color: root.highlight == "msg3" ? Theme.icon_color_danger : Theme.text_primary;
                wrap: word-wrap;
                horizontal-alignment: AppI18n.is-rtl ? right : left;
            }

            // Fourth line: hint text + link
            // - hint non-empty: show hint, append link at end if link is also non-empty
            // - hint empty: if link and url are both non-empty, show only the link
            if root.hint_text != "" || (root.link_text != "" && root.url != ""): HorizontalLayout {
                spacing: 4px;
                alignment: AppI18n.is-rtl ? end : start;
                if root.hint_text != "": Text {
                    text: root.hint_text;
                    font-size: 14px * LayoutConstants.font-scale;
                    font-family: Theme.default_font;
                    color: Theme.text_primary;
                    wrap: no-wrap;
                    vertical-alignment: center;
                }
                if root.link_text != "" && root.url != "": TouchArea {
                    width: link-label.preferred-width;
                    height: link-label.preferred-height;
                    mouse-cursor: pointer;
                    clicked => { root.link_clicked(); }
                    link-label := Text {
                        text: root.link_text;
                        font-size: 14px * LayoutConstants.font-scale;
                        font-family: Theme.default_font;
                        color: parent.has-hover ? Theme.accent.brighter(20%) : Theme.accent;
                        font-weight: 500;
                        wrap: no-wrap;
                        vertical-alignment: center;
                    }
                }
            }
        }

        // Confirm button
        if root.confirm == 1: HorizontalLayout {
            alignment: AppI18n.is-rtl ? start : end;
            CustomButton {
                text: AppI18n.t("dialog.confirm", [AppI18n.version]);
                height: 32px;
                width: 100px;
                primary: true;
                clicked => { root.close(); }
            }
        }
    }
}
