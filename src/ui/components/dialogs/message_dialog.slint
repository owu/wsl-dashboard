import { Theme, AppI18n, LayoutConstants } from "../../theme.slint";
import { CustomButton } from "../form_widgets.slint";

export component MessageDialog inherits Rectangle {
    in property <string> message;
    in property <string> link_text: "";
    in property <string> action_text: "";
    callback close;
    callback link_clicked;
    callback action_clicked;
    width: 440px;
    height: layout.preferred-height;
    background: Theme.card_bg;
    border-radius: 8px;
    border-width: 1px;
    border-color: Theme.border_color;
    drop-shadow-blur: 16px;
    drop-shadow-color: #00000040;
    layout := VerticalLayout {
        padding: 24px;
        spacing: 8px; // matches information_dialog
        alignment: start;

        // Header: title + close button
        Rectangle {
            height: 24px;
            Text {
                x: AppI18n.is-rtl ? 32px : 0;
                width: parent.width - 32px;
                text: AppI18n.t("dialog.info", [AppI18n.version]);
                font-size: 18px * LayoutConstants.font-scale;
                font-family: Theme.default_font;
                font-weight: 500;
                color: Theme.text_primary;
                horizontal-alignment: AppI18n.is-rtl ? right : left;
                vertical-alignment: center;
            }
            TouchArea {
                x: AppI18n.is-rtl ? 0 : parent.width - self.width;
                width: 24px;
                height: 24px;
                clicked => { root.close(); }
                Rectangle {
                    background: parent.has-hover ? Theme.hover_bg : transparent;
                    border-radius: 4px;
                    Text {
                        text: "\u{E8BB}";
                        font-family: Theme.icon_font;
                        font-size: 14px;
                        color: Theme.text_primary;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        // Divider
        Rectangle {
            height: 1px;
            background: Theme.border_color;
        }

        VerticalLayout {
            spacing: 8px;
            Text {
                text: message;
                font-size: 14px * LayoutConstants.font-scale;
                font-family: Theme.default_font;
                color: Theme.text_primary;
                wrap: word-wrap;
                horizontal-alignment: AppI18n.is-rtl ? right : left;
            }

            if root.link_text != "": HorizontalLayout {
                alignment: AppI18n.is-rtl ? end : start;
                TouchArea {
                    width: 100%;
                    mouse-cursor: pointer;
                    clicked => {
                        root.link_clicked();
                    }
                    link_text_item := Text {
                        text: root.link_text;
                        width: 100%;
                        font-size: 14px * LayoutConstants.font-scale;
                        font-family: Theme.default_font;
                        color: parent.has-hover ? Theme.accent.brighter(20%) : Theme.accent;
                        font-weight: 500;
                        wrap: word-wrap;
                        vertical-alignment: center;
                        horizontal-alignment: AppI18n.is-rtl ? right : left;
                    }
                }
            }
            if root.action_text != "": HorizontalLayout {
                alignment: AppI18n.is-rtl ? end : start;
                TouchArea {
                    width: 100%;
                    mouse-cursor: pointer;
                    clicked => {
                        root.action_clicked();
                    }
                    action_text_item := Text {
                        text: root.action_text;
                        width: 100%;
                        font-size: 14px * LayoutConstants.font-scale;
                        font-family: Theme.default_font;
                        color: parent.has-hover ? Theme.accent.brighter(20%) : Theme.accent;
                        font-weight: 500;
                        wrap: word-wrap;
                        vertical-alignment: center;
                        horizontal-alignment: AppI18n.is-rtl ? right : left;
                    }
                }
            }
        }

        HorizontalLayout {
            alignment: AppI18n.is-rtl ? start : end;
            CustomButton {
                text: AppI18n.t("dialog.confirm", [AppI18n.version]);
                height: 32px;
                width: 100px;
                primary: true;
                clicked => {
                    root.close();
                }
            }
        }
    }
}
