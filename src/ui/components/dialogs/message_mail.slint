import { Theme, AppI18n, LayoutConstants, MessageData } from "../../theme.slint";
import { CustomScrollbar } from "../scrollbar.slint";

export component MessageMailDialog inherits Rectangle {
    in property <[MessageData]> messages: [];
    in property <int> unread_count: 0;
    private property <int> page_size: 6;
    private property <length> item_height: 44px;

    callback message_clicked(string, string);
    callback mark_all_read();
    callback close();

    width: 480px;
    height: max(200px, layout.preferred-height);
    background: Theme.card_bg;
    border-radius: 12px;
    border-width: 1px;
    border-color: Theme.border_color;
    drop-shadow-blur: 20px;
    drop-shadow-color: #00000040;
    clip: true;

    layout := VerticalLayout {
        padding: 16px;
        spacing: 8px;

        // Header: title + badge + buttons
        Rectangle {
            height: 24px;
            HorizontalLayout {
                spacing: 8px;

                // RTL: buttons on left, title on right
                if AppI18n.is-rtl: HorizontalLayout {
                    spacing: 4px;

                    // Close button
                    close-touch-rtl := TouchArea {
                        width: 24px;
                        height: 24px;
                        clicked => { root.close(); }
                        Rectangle {
                            background: close-touch-rtl.has-hover ? Theme.hover_bg : transparent;
                            border-radius: 4px;
                            Text {
                                text: "\u{E8BB}";
                                font-family: Theme.icon_font;
                                font-size: 14px;
                                color: Theme.text_primary;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }

                    // Mark all read button
                    if root.unread_count > 0: mark-all-touch-rtl := TouchArea {
                        width: 24px;
                        height: 24px;
                        mouse-cursor: pointer;
                        clicked => { root.mark_all_read(); }
                        Rectangle {
                            background: mark-all-touch-rtl.has-hover ? Theme.hover_bg : transparent;
                            border-radius: 4px;
                            Text {
                                text: "\u{E8BD}";
                                font-family: Theme.icon_font;
                                font-size: 14px;
                                color: mark-all-touch-rtl.has-hover ? Theme.accent : Theme.text_secondary;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }

                        // Tooltip
                        Rectangle {
                            visible: mark-all-touch-rtl.has-hover;
                            opacity: mark-all-touch-rtl.has-hover ? 1 : 0;
                            background: Theme.dark_mode ? #3E3E42 : #F0F0F0;
                            border-color: Theme.border_color;
                            border-width: 1px;
                            border-radius: 4px;
                            z: 100;
                            x: (parent.width - self.width) / 2;
                            y: parent.height + 4px;
                            width: tt-text-rtl.width + 12px;
                            height: tt-text-rtl.height + 6px;
                            drop-shadow-blur: 4px;
                            drop-shadow-color: #00000018;
                            tt-text-rtl := Text {
                                text: AppI18n.t("mail.mark_all_read", [AppI18n.version]);
                                color: Theme.text_primary;
                                font-size: 11px * LayoutConstants.font-scale;
                                font-family: Theme.default_font;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                // LTR: title + badge on left
                if !AppI18n.is-rtl: HorizontalLayout {
                    spacing: 8px;

                    Text {
                        text: AppI18n.t("mail.title", [AppI18n.version]);
                        font-size: 15px * LayoutConstants.font-scale;
                        font-family: Theme.default_font;
                        font-weight: 500;
                        color: Theme.text_primary;
                        vertical-alignment: center;
                    }

                    // Unread count badge
                    if root.unread_count > 0: Rectangle {
                        width: badge-text.width + 12px;
                        height: 18px;
                        border-radius: 9px;
                        background: Theme.icon_color_danger;
                        y: (parent.height - self.height) / 2;

                        badge-text := Text {
                            text: root.unread_count;
                            font-size: 11px;
                            font-family: Theme.default_font;
                            color: #FFFFFF;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }

                // Spacer
                Rectangle { horizontal-stretch: 1; }

                // RTL: title + badge on right
                if AppI18n.is-rtl: HorizontalLayout {
                    spacing: 8px;

                    // Unread count badge
                    if root.unread_count > 0: Rectangle {
                        width: badge-text-rtl.width + 12px;
                        height: 18px;
                        border-radius: 9px;
                        background: Theme.icon_color_danger;
                        y: (parent.height - self.height) / 2;

                        badge-text-rtl := Text {
                            text: root.unread_count;
                            font-size: 11px;
                            font-family: Theme.default_font;
                            color: #FFFFFF;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    Text {
                        text: AppI18n.t("mail.title", [AppI18n.version]);
                        font-size: 15px * LayoutConstants.font-scale;
                        font-family: Theme.default_font;
                        font-weight: 500;
                        color: Theme.text_primary;
                        horizontal-alignment: right;
                        vertical-alignment: center;
                    }
                }

                // LTR: buttons on right
                if !AppI18n.is-rtl: HorizontalLayout {
                    spacing: 4px;

                    // Mark all read button
                    if root.unread_count > 0: mark-all-touch-ltr := TouchArea {
                        width: 24px;
                        height: 24px;
                        mouse-cursor: pointer;
                        clicked => { root.mark_all_read(); }
                        Rectangle {
                            background: mark-all-touch-ltr.has-hover ? Theme.hover_bg : transparent;
                            border-radius: 4px;
                            Text {
                                text: "\u{E8BD}";
                                font-family: Theme.icon_font;
                                font-size: 14px;
                                color: mark-all-touch-ltr.has-hover ? Theme.accent : Theme.text_secondary;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }

                        // Tooltip
                        Rectangle {
                            visible: mark-all-touch-ltr.has-hover;
                            opacity: mark-all-touch-ltr.has-hover ? 1 : 0;
                            background: Theme.dark_mode ? #3E3E42 : #F0F0F0;
                            border-color: Theme.border_color;
                            border-width: 1px;
                            border-radius: 4px;
                            z: 100;
                            x: (parent.width - self.width) / 2;
                            y: parent.height + 4px;
                            width: tt-text-ltr.width + 12px;
                            height: tt-text-ltr.height + 6px;
                            drop-shadow-blur: 4px;
                            drop-shadow-color: #00000018;
                            tt-text-ltr := Text {
                                text: AppI18n.t("mail.mark_all_read", [AppI18n.version]);
                                color: Theme.text_primary;
                                font-size: 11px * LayoutConstants.font-scale;
                                font-family: Theme.default_font;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }

                    // Close button
                    close-touch-ltr := TouchArea {
                        width: 24px;
                        height: 24px;
                        clicked => { root.close(); }
                        Rectangle {
                            background: close-touch-ltr.has-hover ? Theme.hover_bg : transparent;
                            border-radius: 4px;
                            Text {
                                text: "\u{E8BB}";
                                font-family: Theme.icon_font;
                                font-size: 14px;
                                color: Theme.text_primary;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }

        // Divider
        Rectangle {
            height: 1px;
            background: Theme.border_color;
        }

        // Content: message list with scrolling
        if root.messages.length == 0: Rectangle {
            height: 120px;
            clip: true;
            Text {
                text: AppI18n.t("mail.empty", [AppI18n.version]);
                font-size: 14px * LayoutConstants.font-scale;
                font-family: Theme.default_font;
                color: Theme.text_secondary;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        if root.messages.length > 0: Rectangle {
            height: min(root.page_size * root.item_height, root.messages.length * root.item_height);
            clip: true;

            flick := Flickable {
                viewport-height: root.messages.length * root.item_height;
                width: 100%;
                height: 100%;

                VerticalLayout {
                    for msg in root.messages: Rectangle {
                        height: root.item_height;
                        background: msg-touch.has-hover ? Theme.hover_bg : transparent;

                        msg-touch := TouchArea {
                            mouse-cursor: pointer;
                            clicked => {
                                root.message_clicked(msg.id, msg.url);
                            }
                        }

                        HorizontalLayout {
                            padding-left: AppI18n.is-rtl ? 16px : 16px;
                            padding-right: AppI18n.is-rtl ? 16px : 16px;
                            spacing: 8px;

                            // RTL: content flows right to left
                            if AppI18n.is-rtl: Text {
                                text: msg.create_time_text;
                                font-size: 11px * LayoutConstants.font-scale;
                                font-family: Theme.default_font;
                                color: Theme.text_secondary;
                                vertical-alignment: center;
                                opacity: msg.is_read ? 0.5 : 0.8;
                            }

                            if AppI18n.is-rtl: Text {
                                text: msg.title;
                                font-size: 13px * LayoutConstants.font-scale;
                                font-family: Theme.default_font;
                                font-weight: msg.is_read ? 400 : 500;
                                color: msg.is_read ? Theme.text_secondary : Theme.text_primary;
                                vertical-alignment: center;
                                overflow: elide;
                                horizontal-stretch: 1;
                                horizontal-alignment: right;
                                opacity: msg.is_read ? 0.6 : 1.0;
                            }

                            if AppI18n.is-rtl: Text {
                                text: msg.msg_type == "warning" ? "\u{E7BA}"
                                    : msg.msg_type == "error" ? "\u{E783}"
                                    : msg.msg_type == "success" ? "\u{E930}"
                                    : msg.msg_type == "update" ? "\u{E895}"
                                    : "\u{E946}";
                                font-family: Theme.icon_font;
                                font-size: 14px;
                                color: msg.is_read ? Theme.text_secondary : (
                                    msg.msg_type == "warning" ? #FFB900
                                    : msg.msg_type == "error" ? Theme.icon_color_danger
                                    : msg.msg_type == "success" ? #107C10
                                    : Theme.accent
                                );
                                vertical-alignment: center;
                                opacity: msg.is_read ? 0.5 : 1.0;
                            }

                            if AppI18n.is-rtl: Rectangle {
                                width: msg.is_read ? 0px : 6px;
                                height: msg.is_read ? 0px : 6px;
                                border-radius: 3px;
                                background: Theme.accent;
                                y: (parent.height - self.height) / 2;
                            }

                            // LTR: content flows left to right
                            if !AppI18n.is-rtl: Rectangle {
                                width: msg.is_read ? 0px : 6px;
                                height: msg.is_read ? 0px : 6px;
                                border-radius: 3px;
                                background: Theme.accent;
                                y: (parent.height - self.height) / 2;
                            }

                            if !AppI18n.is-rtl: Text {
                                text: msg.msg_type == "warning" ? "\u{E7BA}"
                                    : msg.msg_type == "error" ? "\u{E783}"
                                    : msg.msg_type == "success" ? "\u{E930}"
                                    : msg.msg_type == "update" ? "\u{E895}"
                                    : "\u{E946}";
                                font-family: Theme.icon_font;
                                font-size: 14px;
                                color: msg.is_read ? Theme.text_secondary : (
                                    msg.msg_type == "warning" ? #FFB900
                                    : msg.msg_type == "error" ? Theme.icon_color_danger
                                    : msg.msg_type == "success" ? #107C10
                                    : Theme.accent
                                );
                                vertical-alignment: center;
                                opacity: msg.is_read ? 0.5 : 1.0;
                            }

                            if !AppI18n.is-rtl: Text {
                                text: msg.title;
                                font-size: 13px * LayoutConstants.font-scale;
                                font-family: Theme.default_font;
                                font-weight: msg.is_read ? 400 : 500;
                                color: msg.is_read ? Theme.text_secondary : Theme.text_primary;
                                vertical-alignment: center;
                                overflow: elide;
                                horizontal-stretch: 1;
                                opacity: msg.is_read ? 0.6 : 1.0;
                            }

                            if !AppI18n.is-rtl: Text {
                                text: msg.create_time_text;
                                font-size: 11px * LayoutConstants.font-scale;
                                font-family: Theme.default_font;
                                color: Theme.text_secondary;
                                vertical-alignment: center;
                                opacity: msg.is_read ? 0.5 : 0.8;
                            }
                        }

                        // Bottom divider
                        Rectangle {
                            y: parent.height - self.height;
                            height: 1px;
                            background: Theme.border_color;
                            x: 16px;
                            width: parent.width - 32px;
                        }
                    }
                }
            }

            // Custom scrollbar
            if flick.viewport-height > flick.height: scrollbar := CustomScrollbar {
                x: AppI18n.is-rtl ? 2px : parent.width - self.width - 2px;
                width: 6px;
                height: parent.height;
                maximum: flick.viewport-height - flick.height;
                page_size: flick.height;
                value: -flick.viewport-y;
                scroll_to(v) => { flick.viewport-y = -v; }
            }
        }
    }
}
