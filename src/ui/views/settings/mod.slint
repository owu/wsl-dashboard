import { Theme, AppI18n, SettingsStrings, LayoutConstants } from "../../theme.slint";
import { CustomScrollbar } from "../../components/scrollbar.slint";
import { LanguageData } from "../../components/language_data.slint";
import { 
    CustomCheckBox, 
    CustomButton 
} from "../../components/form_widgets.slint";
import {
    GeneralSettingsSection,
    AdvancedSettingsSection,
    InterfaceSettingsSection
} from "sections.slint";
component SettingsTab inherits Rectangle {
    in property <string> text;
    in property <bool> active: false;
    callback clicked;

    width: tab-label.preferred-width + 24px;
    height: 32px;
    border-top-left-radius: 6px;
    border-top-right-radius: 6px;
    border-bottom-left-radius: 0px;
    border-bottom-right-radius: 0px;
    background: active ? Theme.accent.with-alpha(0.12) : (touch.has-hover ? Theme.hover_bg : Theme.background);
    animate background { duration: 150ms; }

    tab-label := Text {
        text: root.text;
        color: active ? Theme.accent : Theme.text_secondary;
        font-size: 13px * LayoutConstants.font-scale;
        font-weight: 400;
        font-family: Theme.default_font;
        horizontal-alignment: center;
        vertical-alignment: center;
        animate color { duration: 150ms; }
    }

    if active: Rectangle {
        y: parent.height - 2px;
        height: 2px;
        width: parent.width * 0.6;
        x: (parent.width - self.width) / 2;
        background: Theme.accent;
        border-radius: 1px;
    }

    touch := TouchArea {
        clicked => { root.clicked(); }
    }
}

export component SettingsView inherits Rectangle {
    in-out property <string> ui_language: "auto";
    in-out property <string> distro_location: "";
    in-out property <string> logs_location: "";
    in-out property <int> log_level: 4;
    in-out property <int> log_days: 7;
    in-out property <int> check_update_interval: 7;
    in-out property <bool> system_color: false;
    in-out property <bool> auto_shutdown: false;
    in-out property <bool> tray_autostart: false;
    in-out property <bool> tray_start_minimized: false;
    in-out property <bool> tray_close_to_tray: true;
    in-out property <bool> sidebar_add: true;
    in-out property <bool> sidebar_toggle: true;
    in-out property <bool> sidebar_usb: true;
    in-out property <bool> sidebar_network: true;
    in-out property <bool> sidebar_donate: true;
    in-out property <bool> sidebar_about: true;
    in-out property <bool> sparse_vhd: false;
    in-out property <bool> colorful_icons: false;
    in-out property <bool> mail_icon_always: true;
    in-out property <bool> hide_pin_icon: false;
    in property <SettingsStrings> strings;
    in property <[string]> language_options;
    in-out property <int> selected_language_index;

    property <int> active_tab: 0;
    in-out property <bool> show_language_dialog: false;

    // Options Models
    private property <[string]> log-level-options: [
        AppI18n.t("settings.log_levels.error", [AppI18n.version]), AppI18n.t("settings.log_levels.warn", [AppI18n.version]),
        AppI18n.t("settings.log_levels.info", [AppI18n.version]), AppI18n.t("settings.log_levels.debug", [AppI18n.version]),
        AppI18n.t("settings.log_levels.trace", [AppI18n.version])
    ];
    private property <[string]> log-days-options: [
        AppI18n.t("settings.log_retention_options.seven_days", [AppI18n.version]),
        AppI18n.t("settings.log_retention_options.half_month", [AppI18n.version]),
        AppI18n.t("settings.log_retention_options.one_month", [AppI18n.version])
    ];
    private property <[string]> check-update-options: [
        AppI18n.t("settings.update_options.daily", [AppI18n.version]), AppI18n.t("settings.update_options.weekly", [AppI18n.version]),
        AppI18n.t("settings.update_options.biweekly", [AppI18n.version]), AppI18n.t("settings.update_options.monthly", [AppI18n.version])
    ];

    // Selected Indices
    property <int> selected-log-level-index: get-log-level-index(log_level);
    property <int> selected-check-update-index: get-check-update-index(check_update_interval);
    property <int> selected-log-days-index: get-log-days-index(log_days);

    // Sync back indices to properties
    changed selected_language_index => {
        ui_language = LanguageData.lang-codes[selected_language_index];
    }
    changed selected-log-level-index => {
        log_level = selected-log-level-index + 1;
    }
    changed selected-check-update-index => {
        if (selected-check-update-index == 0) { check_update_interval = 1; }
        else if (selected-check-update-index == 1) { check_update_interval = 7; }
        else if (selected-check-update-index == 2) { check_update_interval = 15; }
        else if (selected-check-update-index == 3) { check_update_interval = 30; }
    }
    changed selected-log-days-index => {
        if (selected-log-days-index == 0) { log_days = 7; }
        else if (selected-log-days-index == 1) { log_days = 15; }
        else if (selected-log-days-index == 2) { log_days = 30; }
    }

    pure function get-log-level-index(level: int) -> int {
        if (level >= 1 && level <= 5) { return level - 1; }
        return 2;
    }
    pure function get-check-update-index(interval: int) -> int {
        if (interval == 1) { return 0; }
        if (interval == 7) { return 1; }
        if (interval == 15) { return 2; }
        if (interval == 30) { return 3; }
        return 1;
    }
    pure function get-log-days-index(days: int) -> int {
        if (days == 30) { return 2; }
        if (days == 15) { return 1; }
        return 0;
    }

    callback save_general_settings();
    callback save_advanced_settings();
    callback save_interface_settings();
    callback select-distro-folder();
    callback select-logs-folder();
    callback open-wsl-settings();
    callback stop-wsl();
    callback language_selected(string);
    language_selected(lang_code) => {
        ui_language = lang_code;
    }

    VerticalLayout {
        padding: 0px;
        spacing: 0px;

        // Tab Bar
        HorizontalLayout {
            height: 40px;
            padding-top: 8px;
            padding-bottom: 0px;
            padding-left: 4px;
            padding-right: 8px;
            spacing: 4px;
            alignment: AppI18n.is-rtl ? end : start;

            if (AppI18n.is-rtl): SettingsTab { text: root.strings.tab_interface; active: root.active_tab == 2; clicked => { root.active_tab = 2; } }
            if (AppI18n.is-rtl): SettingsTab { text: root.strings.tab_advanced; active: root.active_tab == 1; clicked => { root.active_tab = 1; } }
            if (AppI18n.is-rtl): SettingsTab { text: root.strings.tab_general; active: root.active_tab == 0; clicked => { root.active_tab = 0; } }

            if (!AppI18n.is-rtl): SettingsTab { text: root.strings.tab_general; active: root.active_tab == 0; clicked => { root.active_tab = 0; } }
            if (!AppI18n.is-rtl): SettingsTab { text: root.strings.tab_advanced; active: root.active_tab == 1; clicked => { root.active_tab = 1; } }
            if (!AppI18n.is-rtl): SettingsTab { text: root.strings.tab_interface; active: root.active_tab == 2; clicked => { root.active_tab = 2; } }
        }

        // Divider
        HorizontalLayout {
            padding-left: AppI18n.is-rtl ? 16px : 4px;
            padding-right: AppI18n.is-rtl ? 4px : 16px;
            Rectangle {
                height: 1px;
                background: Theme.border_color;
            }
        }

        // Tab Content
        Rectangle {
            if (root.active_tab == 0): Rectangle {
                clip: true;
                flickable-general := Flickable {
                    viewport-height: general-layout.preferred-height; width: parent.width; height: 100%;
                    general-layout := VerticalLayout {
                        padding-left: AppI18n.is-rtl ? 16px : 4px; padding-right: AppI18n.is-rtl ? 4px : 16px; padding-top: 4px; padding-bottom: 4px;
                        GeneralSettingsSection {
                            strings: root.strings;
                            selected_language_index <=> root.selected_language_index;
                            selected_check_update_index <=> root.selected-check-update-index;
                            language_options: root.language_options;
                            check_update_options: root.check-update-options;
                            show_language_dialog <=> root.show_language_dialog;
                            tray_autostart <=> root.tray_autostart;
                            tray_start_minimized <=> root.tray_start_minimized;
                            tray_close_to_tray <=> root.tray_close_to_tray;
                        }
                    }
                }
                if (flickable-general.viewport-height > flickable-general.height): CustomScrollbar {
                    x: AppI18n.is-rtl ? 4px : parent.width - 10px; y: 0; width: 8px; height: 100%;
                    maximum: flickable-general.viewport-height - flickable-general.height; page_size: flickable-general.height;
                    value: -flickable-general.viewport-y; scroll_to(v) => { flickable-general.viewport-y = -v; }
                }
            }
            
            if (root.active_tab == 1): Rectangle {
                clip: true;
                flickable-advanced := Flickable {
                    viewport-height: advanced-layout.preferred-height; width: parent.width; height: 100%;
                    advanced-layout := VerticalLayout {
                        padding-left: AppI18n.is-rtl ? 16px : 4px; padding-right: AppI18n.is-rtl ? 4px : 16px; padding-top: 4px; padding-bottom: 4px;
                        AdvancedSettingsSection {
                            strings: root.strings;
                            distro_location <=> root.distro_location;
                            logs_location <=> root.logs_location;
                            selected_log_level_index <=> root.selected-log-level-index;
                            selected_log_days_index <=> root.selected-log-days-index;
                            log_level_options: root.log-level-options;
                            log_days_options: root.log-days-options;
                            auto_shutdown <=> root.auto_shutdown;
                            sparse_vhd <=> root.sparse_vhd;
                            select_distro_folder => { root.select-distro-folder(); }
                            select_logs_folder => { root.select-logs-folder(); }
                        }
                    }
                }
                if (flickable-advanced.viewport-height > flickable-advanced.height): CustomScrollbar {
                    x: AppI18n.is-rtl ? 4px : parent.width - 10px; y: 0; width: 8px; height: 100%;
                    maximum: flickable-advanced.viewport-height - flickable-advanced.height; page_size: flickable-advanced.height;
                    value: -flickable-advanced.viewport-y; scroll_to(v) => { flickable-advanced.viewport-y = -v; }
                }
            }
            
            if (root.active_tab == 2): Rectangle {
                clip: true;
                flickable-interface := Flickable {
                    viewport-height: interface-layout.preferred-height; width: parent.width; height: 100%;
                    interface-layout := VerticalLayout {
                        padding-left: AppI18n.is-rtl ? 16px : 4px; padding-right: AppI18n.is-rtl ? 4px : 16px; padding-top: 4px; padding-bottom: 4px;
                        InterfaceSettingsSection {
                            strings: root.strings;
                            sidebar_add <=> root.sidebar_add;
                            sidebar_toggle <=> root.sidebar_toggle;
                            sidebar_usb <=> root.sidebar_usb;
                            sidebar_network <=> root.sidebar_network;
                            sidebar_donate <=> root.sidebar_donate;
                            sidebar_about <=> root.sidebar_about;
                            system_color <=> root.system_color;
                            colorful_icons <=> root.colorful_icons;
                            mail_icon_always <=> root.mail_icon_always;
                            hide_pin_icon <=> root.hide_pin_icon;
                        }
                    }
                }
                if (flickable-interface.viewport-height > flickable-interface.height): CustomScrollbar {
                    x: AppI18n.is-rtl ? 4px : parent.width - 10px; y: 0; width: 8px; height: 100%;
                    maximum: flickable-interface.viewport-height - flickable-interface.height; page_size: flickable-interface.height;
                    value: -flickable-interface.viewport-y; scroll_to(v) => { flickable-interface.viewport-y = -v; }
                }
            }
        }

        // Action Buttons
        HorizontalLayout {
            padding-top: 12px;
            padding-bottom: 4px;
            padding-left: AppI18n.is-rtl ? 16px : 4px;
            padding-right: AppI18n.is-rtl ? 4px : 16px;
            spacing: 8px;

            if (AppI18n.is-rtl): CustomButton {
                text: root.strings.save; primary: true; height: 32px; width: 80px;
                clicked => {
                    if (root.active_tab == 0) { root.save_general_settings(); }
                    if (root.active_tab == 1) { root.save_advanced_settings(); }
                    if (root.active_tab == 2) { root.save_interface_settings(); }
                }
            }
            
            if (AppI18n.is-rtl): Rectangle { horizontal-stretch: 1; }
            
            if (AppI18n.is-rtl && root.active_tab == 0): CustomButton {
                text: root.strings.stop_wsl; height: 32px;
                clicked => { root.stop-wsl(); }
            }

            if (AppI18n.is-rtl && root.active_tab == 0): CustomButton {
                text: root.strings.wsl_settings; height: 32px;
                clicked => { root.open-wsl-settings(); }
            }

            if (!AppI18n.is-rtl && root.active_tab == 0): CustomButton {
                text: root.strings.wsl_settings; height: 32px;
                clicked => { root.open-wsl-settings(); }
            }

            if (!AppI18n.is-rtl && root.active_tab == 0): CustomButton {
                text: root.strings.stop_wsl; height: 32px;
                clicked => { root.stop-wsl(); }
            }

            if (!AppI18n.is-rtl): Rectangle { horizontal-stretch: 1; }

            if (!AppI18n.is-rtl): CustomButton {
                text: root.strings.save; primary: true; height: 32px; width: 80px;
                clicked => {
                    if (root.active_tab == 0) { root.save_general_settings(); }
                    if (root.active_tab == 1) { root.save_advanced_settings(); }
                    if (root.active_tab == 2) { root.save_interface_settings(); }
                }
            }
        }
    }
}
