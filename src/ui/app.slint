        close_wsl_compat => {
            root.show_wsl_compat_dialog = false;
        }
        wsl_compat_link_clicked => {
            root.open_url(root.wsl_compat_issues_url);
            root.show_wsl_compat_dialog = false;
        }

        // Popup Notice Dialog
        show_popup_notice: root.show_popup_notice_dialog;
        popup_notice_title: root.popup_notice_title;
        popup_notice_msg1: root.popup_notice_msg1;
        popup_notice_msg2: root.popup_notice_msg2;
        popup_notice_msg3: root.popup_notice_msg3;
        popup_notice_hint: root.popup_notice_hint;
        popup_notice_link: root.popup_notice_link;
        popup_notice_url: root.popup_notice_url;
        popup_notice_highlight: root.popup_notice_highlight;
        popup_notice_confirm: root.popup_notice_confirm;
        close_popup_notice => {
            root.show_popup_notice_dialog = false;
        }
        popup_notice_link_clicked => {
            root.open_url(root.popup_notice_url);
            root.show_popup_notice_dialog = false;
        }

        // Popup Image Dialog
        show_popup_image: root.show_popup_image_dialog;
        popup_image_source: root.popup_image_source;
        popup_image_title: root.popup_image_title;
        popup_image_url: root.popup_image_url;
        popup_image_width: root.popup_image_width;
        popup_image_height: root.popup_image_height;
        close_popup_image => {
            root.show_popup_image_dialog = false;
        }
        popup_image_clicked => {
            root.open_url(root.popup_image_url);
            root.show_popup_image_dialog = false;
        }

        // System message popup
        show_mail_popup: root.show_mail_popup;
        mail_messages: root.mail_messages;
        mail_unread_count: root.mail_unread_count;
        mail_message_clicked(id, url) => {
            root.mail_message_clicked(id, url);
        }
        mail_mark_all_read => {
            root.mail_mark_all_read();
        }
        mail_close => {
            root.show_mail_popup = false;
        }
    }

    // Official communication group image popup layer (borderless, click anywhere to close)
    if root.show_group_popup : Rectangle {
        background: #00000080;
        z: 100;
        width: 100%;
        height: 100%;
        TouchArea {
            width: 100%;
            height: 100%;
            clicked => {
                root.show_group_popup = false;
            }
        }
        // Centered image card, 3:4 aspect ratio, borderless
        Rectangle {
            width: 225px;
            height: 300px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            border-radius: 12px;
            clip: true;
            drop-shadow-blur: 20px;
            drop-shadow-color: #00000040;
            Image {
                source: root.about_group_pic;
                width: 100%;
                height: 100%;
                image-fit: cover;
            }
        }
    }

    // Donate QR code popup layer
    if root.show_donate_popup : Rectangle {
        background: #00000080;
        z: 100;
        width: 100%;
        height: 100%;
        TouchArea {
            width: 100%;
            height: 100%;
            clicked => {
                root.show_donate_popup = false;
            }
        }
        // Centered square image card
        Rectangle {
            width: 225px;
            height: 225px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            border-radius: 12px;
            clip: true;
            drop-shadow-blur: 20px;
            drop-shadow-color: #00000040;
            background: Theme.card_bg;
            if (root.donate_popup_loading) : Text {
                text: AppI18n.t("donate.loading", [AppI18n.version]);
                color: Theme.text_primary;
                font-family: Theme.default_font;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
            if (!root.donate_popup_loading) : Image {
                source: root.donate_popup_image;
                width: 100%;
                height: 100%;
                image-fit: contain;
            }
        }
    }
}
