        // Language Select Dialog
        show_language_dialog <=> root.show_language_dialog;
        language_current_index: root.selected_language_index;
        language_options: LanguageData.options;
        language_selected(idx) => {
            root.language_selected(idx);
        }

        // WSL Compat Dialog
        show_wsl_compat: root.show_wsl_compat_dialog;
        wsl_compat_msg1: root.wsl_compat_msg1;
        wsl_compat_msg2: root.wsl_compat_msg2;
        wsl_compat_msg3: root.wsl_compat_msg3;
