                                start_distro(n) => {
                                    root.start_distro(n);
                                }
                                stop_distro(n) => {
                                    root.stop_distro(n);
                                }
                                restart_distro(n) => {
                                    root.restart_distro(n);
                                }
                                terminal_distro(n) => {
                                    root.terminal_distro(n);
                                }
                                folder_distro(n) => {
                                    root.folder_distro(n);
                                }
                                vscode_distro(n) => {
                                    root.vscode_distro(n);
                                }
                                edit_bashrc_distro(n) => {
