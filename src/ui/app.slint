    // Dynamic Font Selection to optimize memory usage
    // Helper function to map language to font (No recursion here)
    pure function resolve-font(lang: string) -> string {


        // Compatibility of Chinese and Japanese character display on Western language operating systems
        // Group 1: CJK (High Memory Impact)
        if (lang == "zh-CN" || lang == "zh-Hans-CN" || lang == "zh-SG") {
            return "Microsoft YaHei UI";
        }
        if (lang == "zh-TW" || lang == "zh-Hant-TW" || lang == "zh-HK" || lang == "zh-MO") {
            return "Microsoft JhengHei UI";
        }
        if (lang == "ja") {
            return "Yu Gothic UI";
        }
        
        // Group 2: Indic Scripts (Medium Impact)
        if (lang == "hi" || lang == "bn" || 
            lang == "te" || lang == "ta" ||      // Telugu, Tamil
            lang == "kn" || lang == "mr" ||      // Kannada, Marathi
            lang == "ml") {                      // Malayalam
            return "Nirmala UI";
        }

        // Group 3: Southeast Asian Scripts
        if (lang == "th") {                      // Thai
            return "Tahoma";
        }
        if (lang == "my") {                      // Burmese
            return "Myanmar Text";
        }

        // Group 4: African Scripts
        if (lang == "am") {                      // Amharic (Ge'ez)
            return "Ebrima";
        }

        // Group 5: Default (Western/Cyrillic/Arabic - Low Memory Impact)
        // Segoe UI covers all Latin and Cyrillic scripts efficiently.
        return "Segoe UI";
    }

    // Main function with smart fallback logic
    pure function get-font(lang: string) -> string {
        // Optimization: On Chinese Windows, Windows DirectWrite font fallback
        // handles CJK characters automatically. No need to specify explicit CJK
        // fonts → saves ~16MB memory by avoiding CJK glyph atlas allocation.
        let sys = root.system_language;
        let sys_is_chinese = (sys == "zh" || sys == "zh-CN" || sys == "zh-TW" ||
                              sys == "zh-Hans" || sys == "zh-Hant" || sys == "zh-SG" ||
                              sys == "zh-HK" || sys == "zh-MO");
        if (sys_is_chinese) {
            return "Segoe UI";
        }

        // Non-Chinese Windows: need explicit CJK fonts for compatibility
        if (lang == "auto") {
            if (root.system_language == "auto") {
                return "Microsoft YaHei UI";
            }
            return resolve-font(root.system_language);
        }
        return resolve-font(lang);
    }
    init => {
        Theme.default_font = root.get-font(root.ui_language);
    }


    // --- Main Layout ---
    Rectangle {
        background: Theme.background;
        border-radius: 8px;
        clip: true;
        border-width: 1px;
        border-color: Theme.main_color;
        VerticalLayout {
            TitleBar {
                title: AppI18n.t("common.app_name", [AppI18n.version]);
                is_maximized: root.is_maximized;
                is_pinned: root.is_pinned;
                pin_toggle => {
                    root.window_pin_toggle();
                }
                mail_unread_count: root.mail_unread_count;
                mail_icon_always: root.mail_icon_always;
                hide_pin_icon: root.hide_pin_icon;
                close => {
                    root.window_close();
                }
                minimize => {
                    root.window_minimize();
                }
                toggle_theme => {
                    Theme.dark_mode = !Theme.dark_mode;
                    root.toggle_theme();
                }
                drag_delta(dx, dy) => {
                    root.window_drag_delta(dx, dy);
                }
                mail_clicked => {
                    root.mail_clicked();
                }
            }

            Rectangle {
                sidebar := Sidebar {
                    x: AppI18n.is-rtl ? parent.width - self.width : 0;
                    height: 100%;
                    collapsed <=> root.sidebar_collapsed;
                    selected_tab: root.selected_tab;
                    home_text: AppI18n.t("sidebar.home", [AppI18n.version]);
                    add_text: AppI18n.t("sidebar.add", [AppI18n.version]);
                    usb_text: AppI18n.t("sidebar.usb", [AppI18n.version]);
                    network_text: AppI18n.t("sidebar.network", [AppI18n.version]);
                    settings_text: AppI18n.t("sidebar.settings", [AppI18n.version]);
                    about_text: AppI18n.t("sidebar.about", [AppI18n.version]);
                    donate_text: AppI18n.t("sidebar.donate", [AppI18n.version]);
                    show_add: root.sidebar_add;
                    show_toggle: root.sidebar_toggle;
                    show_usb: root.sidebar_usb;
                    show_network: root.sidebar_network;
                    show_donate: root.sidebar_donate;
                    show_about: root.sidebar_about;
                    tab_selected(idx) => {
                        root.select_tab(idx);
                    }
                    home_clicked => {
                        root.home_clicked();
                    }
                    toggle_collapsed => {
                        root.save_sidebar_state();
                    }
                }

                Rectangle {
                    x: AppI18n.is-rtl ? 0 : sidebar.width;
                    width: parent.width - sidebar.width;
                    height: 100%;
                    background: Theme.content_bg;
                    border-top-left-radius: AppI18n.is-rtl ? 0 : 8px;
                    border-top-right-radius: AppI18n.is-rtl ? 8px : 0;
                    clip: true;
                    VerticalLayout {
                        padding: 16px;
                        padding-top: 8px;
                        padding-right: AppI18n.is-rtl ? 16px : 6px;
                        padding-left: AppI18n.is-rtl ? 6px : 16px;
                        Rectangle {
                            MainView {
                                visible: true;
                                z: 3;
                                opacity: selected_tab == 0 ? 1 : 0;
                                x: selected_tab == 0 ? 0px : 10000px;
                                distros: root.distros; // Always bind to prevent Repeater churn
                                distro_to_delete <=> root.distro_to_delete;
                                show_delete_confirmation <=> root.show_delete_confirmation;
                                wsl_loading: root.wsl_loading;
                                distro_not_found: root.distro_not_found;
                                wsl_guide_url: root.wsl_guide_url;
                                open_url(url) => {
                                    root.open_url(url);
                                }
                                // ... callbacks omitted for brevity ...
                                start_distro(n) => {
                                    root.start_distro(n);
                                }
                                stop_distro(n) => {
                                    root.stop_distro(n);
                                }
                                restart_distro(n) => {
                                    root.restart_distro(n);
                                }
                                terminal_distro(n) => {
                                    root.terminal_distro(n);
                                }
                                folder_distro(n) => {
                                    root.folder_distro(n);
                                }
                                vscode_distro(n) => {
                                    root.vscode_distro(n);
                                }
                                edit_bashrc_distro(n) => {
                                    root.edit_bashrc_distro(n);
                                }
                                open_export_dialog(n) => {
                                    root.open_export_dialog(n);
                                }
                                open_clone_dialog(n) => {
                                    root.open_clone_dialog(n);
                                }
                                open_move_dialog(n) => {
                                    root.open_move_dialog(n);
                                }
                                information_clicked(n) => {
                                    root.information_clicked(n);
                                }
                                settings_clicked(n) => {
